# Database
DATABASE_URL="postgresql://user:password@localhost:5432/loans_db?schema=public"
PRISMA_CONNECT_MAX_RETRIES=5
PRISMA_CONNECT_RETRY_DELAY_MS=1000
PRISMA_QUERY_RETRY_MAX_ATTEMPTS=3
PRISMA_QUERY_RETRY_BASE_DELAY_MS=250
PRISMA_QUERY_RETRY_MAX_DELAY_MS=2000
PRISMA_QUERY_RETRY_JITTER_MS=100
PRISMA_QUERY_RETRY_ON_WRITE=false

# Application
PORT=3000
NODE_ENV=development

# JWT (para autenticación futura)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Bcrypt
BCRYPT_ROUNDS=10
