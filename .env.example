# Database
DATABASE_URL="postgresql://prisma.<project-ref>:REPLACE_WITH_PRISMA_PASSWORD@aws-1-<region>.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://prisma.<project-ref>:REPLACE_WITH_PRISMA_PASSWORD@aws-1-<region>.pooler.supabase.com:5432/postgres"
PRISMA_CONNECT_MAX_RETRIES=5
PRISMA_CONNECT_RETRY_DELAY_MS=1000
PRISMA_QUERY_RETRY_MAX_ATTEMPTS=3
PRISMA_QUERY_RETRY_BASE_DELAY_MS=250
PRISMA_QUERY_RETRY_MAX_DELAY_MS=2000
PRISMA_QUERY_RETRY_JITTER_MS=100
PRISMA_QUERY_RETRY_ON_WRITE=false

# Application
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000/api

# Supabase Auth (backend)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated

# Supabase Auth (frontend/public)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Legacy JWT (only if some local flow still needs it)
JWT_SECRET=replace-with-a-local-secret-if-still-needed

# Bcrypt
BCRYPT_ROUNDS=10
