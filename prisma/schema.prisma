generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lender {
  id                     String                   @id @default(uuid())
  name                   String
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  clientIntakeSubmissions ClientIntakeSubmission[]
  clients                Client[]
  loans                  Loan[]
  users                  User[]

  @@map("lenders")
}

model User {
  id                             String                   @id @default(uuid())
  email                          String                   @unique
  passwordHash                   String
  role                           UserRole
  lenderId                       String
  isActive                       Boolean                  @default(true)
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  approvedClientIntakeSubmissions ClientIntakeSubmission[] @relation("ClientIntakeApprovedBy")
  client                         Client?
  lender                         Lender                   @relation(fields: [lenderId], references: [id])

  @@map("users")
}

model Client {
  id              String                  @id @default(uuid())
  lenderId        String
  userId          String?                 @unique
  fullName        String
  documentNumber  String
  phone           String?
  address         String?
  notes           String?
  isActive        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  email           String?
  intakeSubmission ClientIntakeSubmission? @relation("ClientCreatedFromIntake")
  lender          Lender                  @relation(fields: [lenderId], references: [id])
  user            User?                   @relation(fields: [userId], references: [id])
  loans           Loan[]
  payments        Payment[]

  @@index([lenderId, isActive])
  @@map("clients")
}

model Loan {
  id                          String                      @id @default(uuid())
  lenderId                    String
  clientId                    String
  type                        LoanType
  principalAmount             Float
  currentPrincipal            Float
  monthlyInterestRate         Float?
  installmentAmount           Float?
  totalInstallments           Int?
  paymentFrequency            PaymentFrequency
  startDate                   DateTime
  expectedEndDate             DateTime?
  status                      LoanStatus                  @default(ACTIVE)
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  earlySettlementInterestMode EarlySettlementInterestMode @default(FULL_MONTH)
  installments                Installment[]
  interests                   LoanInterest[]
  penalties                   LoanPenalty[]
  client                      Client                      @relation(fields: [clientId], references: [id])
  lender                      Lender                      @relation(fields: [lenderId], references: [id])
  payments                    Payment[]

  @@index([lenderId, status])
  @@index([lenderId, status, type])
  @@index([clientId, status])
  @@map("loans")
}

model LoanInterest {
  id              String   @id @default(uuid())
  loanId          String
  periodStartDate DateTime
  periodEndDate   DateTime
  interestAmount  Float
  interestPaid    Float    @default(0)
  interestPending Float
  createdAt       DateTime @default(now())
  loan            Loan     @relation(fields: [loanId], references: [id])

  @@index([loanId, periodStartDate])
  @@index([loanId, periodEndDate])
  @@index([loanId, periodStartDate, interestPaid])
  @@map("loan_interests")
}

model LoanPenalty {
  id              String       @id @default(uuid())
  loanId          String
  daysLate        Int
  penaltyAmount   Float
  wasCharged      Boolean      @default(false)
  calculatedAt    DateTime     @default(now())
  installmentId   String?
  periodEndDate   DateTime?
  periodStartDate DateTime?
  installment     Installment? @relation(fields: [installmentId], references: [id])
  loan            Loan         @relation(fields: [loanId], references: [id])

  @@index([loanId, wasCharged, periodEndDate])
  @@index([loanId, installmentId, wasCharged, periodEndDate])
  @@index([loanId, periodStartDate, periodEndDate])
  @@index([installmentId, periodEndDate])
  @@map("loan_penalties")
}

model Payment {
  id                              String                       @id @default(uuid())
  loanId                          String
  clientId                        String
  totalAmount                     Float
  appliedToInterest               Float                        @default(0)
  appliedToPrincipal              Float                        @default(0)
  appliedToPenalty                Float                        @default(0)
  paymentDate                     DateTime                     @default(now())
  createdAt                       DateTime                     @default(now())
  earlySettlementInterestModeUsed EarlySettlementInterestMode?
  interestDaysCharged             Int?
  isEarlySettlement               Boolean                      @default(false)
  client                          Client                       @relation(fields: [clientId], references: [id])
  loan                            Loan                         @relation(fields: [loanId], references: [id])

  @@index([loanId, paymentDate])
  @@index([clientId, paymentDate])
  @@index([paymentDate])
  @@map("payments")
}

model Installment {
  id                String            @id @default(uuid())
  loanId            String
  installmentNumber Int
  dueDate           DateTime
  amount            Float
  status            InstallmentStatus @default(PENDING)
  loan              Loan              @relation(fields: [loanId], references: [id])
  penalties         LoanPenalty[]

  @@index([loanId, installmentNumber])
  @@index([loanId, status, dueDate])
  @@map("installments")
}

model ClientIntakeSubmission {
  id                  String             @id @default(uuid())
  lenderId            String
  source              ClientIntakeSource
  sourceEventId       String?            @unique
  sourceSubmissionId  String?
  sourceFormId        String?
  sourceFormName      String?
  submittedAt         DateTime
  fullName            String
  documentNumber      String
  email               String?
  phone               String?
  address             String?
  notes               String?
  rawPayload          Json
  status              ClientIntakeStatus @default(PENDING)
  duplicateByDocument Boolean            @default(false)
  duplicateByEmail    Boolean            @default(false)
  duplicateByPhone    Boolean            @default(false)
  rejectionReason     String?
  approvedAt          DateTime?
  approvedByUserId    String?
  createdClientId     String?            @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  approvedBy          User?              @relation("ClientIntakeApprovedBy", fields: [approvedByUserId], references: [id])
  createdClient       Client?            @relation("ClientCreatedFromIntake", fields: [createdClientId], references: [id])
  lender              Lender             @relation(fields: [lenderId], references: [id])

  @@index([lenderId, status, submittedAt])
  @@index([lenderId, documentNumber])
  @@index([lenderId, email])
  @@index([lenderId, phone])
  @@map("client_intake_submissions")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum LoanType {
  FIXED_INSTALLMENTS
  DAILY_INTEREST
  MONTHLY_INTEREST
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum InstallmentStatus {
  PENDING
  PAID
  LATE
}

enum EarlySettlementInterestMode {
  FULL_MONTH
  PRORATED_BY_DAYS
}

enum ClientIntakeSource {
  TALLY
}

enum ClientIntakeStatus {
  PENDING
  APPROVED
  REJECTED
}
